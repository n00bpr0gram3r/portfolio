# =========================================================================
# BBP MONITOR - CONFIGURATION PROFILE
# Copy this file to .env.local and fill in the values.
# =========================================================================

# -------------------------------------------------------------------------
# 1. GISCUS COMMENTS CONFIGURATION (GitHub Discussions backend)
# -------------------------------------------------------------------------
NEXT_PUBLIC_GISCUS_REPO=your-github-username/your-repository-name
NEXT_PUBLIC_GISCUS_REPO_ID=your-giscus-repo-id
NEXT_PUBLIC_GISCUS_CATEGORY=Announcements
NEXT_PUBLIC_GISCUS_CATEGORY_ID=your-giscus-category-id

# -------------------------------------------------------------------------
# 2. SPONSORSHIP LINKS (Ko-fi and UPI config)
# -------------------------------------------------------------------------
# Link to your Ko-fi profile page
NEXT_PUBLIC_KO_FI_URL=https://ko-fi.com/gemsabdul

# Your direct UPI payment address (for GPay/Paytm/PhonePe)
NEXT_PUBLIC_UPI_ID=gemsabdul@okaxis

# -------------------------------------------------------------------------
# 3. CARBON ADS CONFIGURATION
# -------------------------------------------------------------------------
# Leave empty to use the custom "Request Code Audit" fallback banner.
# Fill in once approved by Carbon Ads.
NEXT_PUBLIC_CARBON_SERVE=
NEXT_PUBLIC_CARBON_PLACEMENT=
